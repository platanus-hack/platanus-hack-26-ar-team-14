db-up:
	docker compose up -d postgres

migrate:
	uv run alembic upgrade head

reset:
	docker compose down -v
	heads=$(uv run alembic heads | rg -F -c "(head)"); if [ "$heads" -gt 1 ]; then uv run alembic merge heads -m "merge heads"; else echo "Alembic already has a single head"; fi
	docker compose up -d postgres
	until docker compose exec -T postgres pg_isready -U postgres -d app >/dev/null 2>&1; do sleep 1; done
	uv run alembic upgrade head
	uv run python -m scripts.seed_demo

seed:
	docker compose -f ../docker-compose.dev.yml exec backend python -m scripts.seed_demo

reseed: reset seed

dev-up: db-up migrate
	uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000

dev:
	uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000

dev-docker:
	docker compose -f ../docker-compose.dev.yml up --build

dev-docker-down:
	docker compose -f ../docker-compose.dev.yml down

lint:
	uv run ruff format .
	uv run ruff check .
