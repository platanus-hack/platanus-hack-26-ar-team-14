# Anthropic API key (required)
ANTHROPIC_API_KEY=

# OpenRouter API key (required) — used for embeddings in the curriculum RAG
OPENROUTER_API_KEY=

# Agent model (optional — defaults to claude-haiku-4-5)
# AGENT_MODEL=claude-haiku-4-5

# Embedding model + base URL (optional — defaults to OpenAI text-embedding-3-small via OpenRouter)
# EMBED_MODEL=openai/text-embedding-3-small
# EMBED_BASE_URL=https://openrouter.ai/api/v1

# Postgres connection (optional — defaults to the Docker compose `postgres` service).
# For a host-run backend against the local Compose database, use localhost:5433.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/app

# JWT signing secret (required in prod — generate with: openssl rand -hex 32)
JWT_SECRET=
# JWT_ALGORITHM=HS256
# JWT_EXPIRES_MINUTES=10080

# CORS origins (optional — JSON array)
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# LangSmith tracing (optional)
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=platanus-hack-ar-team-14

# Spreadsheet conversion binary (optional — defaults to `soffice`)
# LIBREOFFICE_BIN=soffice
