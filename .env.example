# Anthropic API key (required)
ANTHROPIC_API_KEY=

# OpenRouter API key (required) — used for embeddings in the curriculum RAG
OPENROUTER_API_KEY=

# Agent model (optional — defaults to claude-haiku-4-5)
# AGENT_MODEL=claude-haiku-4-5

# Embedding model + base URL (optional — defaults to OpenAI text-embedding-3-small via OpenRouter)
# EMBED_MODEL=openai/text-embedding-3-small
# EMBED_BASE_URL=https://openrouter.ai/api/v1

# CORS origins (optional — JSON array)
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# LangSmith tracing (optional)
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=platanus-hack-ar-team-14
